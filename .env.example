# Karbuin environment variables (template)
# Copy file ini ke .env dan isi nilai yang sesuai

# Server config
PORT=8000
HOST=0.0.0.0
KARBUIN_VERSION=1.1.2
KARBUIN_ENV=development

# Production
# KARBUIN_ENV=production
# PORT=8000

# Optional: secret untuk hash telemetry (jika ditambahkan di v1.2+)
# KARBUIN_TELEMETRY_SALT=change-me-in-production

# Render-specific
# RENDER=true  (auto-set oleh Render)
# DATABASE_URL=  (jika pakai Postgres eksternal, saat ini pakai SQLite lokal)